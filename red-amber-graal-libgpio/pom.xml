<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>dev.lofthouse</groupId>
  <artifactId>red-amber-graal-libgpio</artifactId>
  <version>0.0.1-SNAPSHOT</version>

  <name>red-amber-graal-libgpio</name>
  <url>https://lofthouse.dev/</url>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>25</maven.compiler.release>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.junit</groupId>
        <artifactId>junit-bom</artifactId>
        <version>5.14.3</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-api</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <pluginManagement><!-- lock down plugins versions to avoid using Maven defaults (may be moved to parent pom) -->
      <plugins>
        <plugin>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.15.0</version>
        </plugin>
        <plugin>
          <artifactId>maven-jar-plugin</artifactId>
          <configuration>
            <archive>
              <manifest>
                <mainClass>dev.lofthouse.App</mainClass>
              </manifest>
            </archive>
          </configuration>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

  <profiles>
    <profile>
      <id>native</id>
      <activation>
        <property>
          <name>native</name>
        </property>
      </activation>
      <build>
        <plugins>
          <!-- Generate CAP cache before native-image runs. Runs at 'package' phase after
               jar:jar creates the JAR. The skip-jar-build flag avoids a recursive
               Maven invocation from within the Maven lifecycle. -->
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <version>3.5.0</version>
            <executions>
              <execution>
                <id>gen-cap-cache</id>
                <phase>package</phase>
                <goals><goal>exec</goal></goals>
                <configuration>
                  <executable>${project.basedir}/scripts/setup/generate-cap-cache.sh</executable>
                  <arguments>
                    <argument>--skip-jar-build</argument>
                    <argument>--cap-cache-dir=${project.build.directory}/cap-cache</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.graalvm.buildtools</groupId>
            <artifactId>native-maven-plugin</artifactId>
            <version>0.11.4</version>
            <executions>
              <execution>
                <goals>
                  <goal>build</goal>
                </goals>
              </execution>
            </executions>
            <configuration>
              <imageName>red-amber-graal-libgpio-native</imageName>
              <mainClass>dev.lofthouse.App</mainClass>
              <buildArgs>
                <!-- Override CABI for the native-image builder JVM so AbiUtils.create() returns
                     ABIs.LinuxAArch64 instead of ABIs.SysV when cross-compiling to aarch64.
                     Without this, CABI.current() returns the host ABI (SYS_V on x86_64), causing
                     a ClassCastException in ForeignFunctionsFeature when FFM is enabled.
                     See notes/graalvm-ffm-cross-compile-bug.md for full root-cause analysis. -->
                <buildArg>-J-Djdk.internal.foreign.CABI=LINUX_AARCH_64</buildArg>
                <buildArg>--target=linux-aarch64</buildArg>
                <buildArg>--native-compiler-path=/usr/bin/aarch64-linux-gnu-gcc</buildArg>
                <buildArg>--native-compiler-options=--sysroot=${user.home}/mnt/pios12_root</buildArg>
                <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                <buildArg>-H:CAPCacheDir=${project.build.directory}/cap-cache</buildArg>
                <buildArg>-H:CLibraryPath=${user.home}/mnt/pios12_root/usr/lib/aarch64-linux-gnu</buildArg>
              </buildArgs>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
